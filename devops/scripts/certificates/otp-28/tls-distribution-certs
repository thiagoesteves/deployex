#!/usr/bin/env elixir
# Generate certificates
#

Mix.install([
  {:x509, "~> 0.9"}
])

defmodule Script do
  def run do
    certdir = "."
    commonName = "deployex"
    primary_domain = "deployex.pro"
    subdomains = ["www.#{primary_domain}"]

    # Generate CA key + self-signed CA cert
    ca_subject = "/C=BR/ST=Sao Paulo/L=Sao Paulo/O=Acme/CN=ECDSA Root CA"
    ca_key = X509.PrivateKey.new_ec(:secp256r1)
    ca_crt = X509.Certificate.self_signed(ca_key, ca_subject, template: :root_ca)

    File.write!(Path.join(certdir, "ca.crt"), X509.Certificate.to_pem(ca_crt))

    # Build the template
    import X509.Certificate.Extension

    template = %X509.Certificate.Template{
      validity: 365 + 30,
      hash: :sha256,
      extensions: [
        basic_constraints: basic_constraints(false),
        key_usage: key_usage([:digitalSignature, :keyEncipherment]),
        ext_key_usage: ext_key_usage([:serverAuth, :clientAuth]),
        subject_key_identifier: true,
        authority_key_identifier: true,
        subject_alt_name: subject_alt_name([primary_domain] ++ subdomains)
      ]
    }

    # Generate server key and derive public key
    key = X509.PrivateKey.new_ec(:secp256r1)
    pub = X509.PublicKey.derive(key)

    # CA signs the server cert
    cert = X509.Certificate.new(
      pub,
      "/CN=#{primary_domain}",
      ca_crt,
      ca_key,
      template: template
    )

    File.write!(Path.join(certdir, "#{commonName}.key"), X509.PrivateKey.to_pem(key))
    File.write!(Path.join(certdir, "#{commonName}.crt"), X509.Certificate.to_pem(cert))
  end
end

Script.run()
